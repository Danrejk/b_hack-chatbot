# Copy this file to .env and fill in real values. Never commit .env itself.

# LLM provider
OPENAI_API_KEY=sk-replace-me
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=gpt-4o-mini

# Storage (file paths are relative to apps/backend/)
SQLITE_DB_PATH=./data/conversations.db
VECTOR_DB_PATH=./data/milvus_lite.db
VECTOR_COLLECTION_NAME=knowledge_base
EMBEDDING_DIM=1536

# Knowledge base source documents (used by ingestion in a later phase)
KNOWLEDGE_BASE_DIR=../../data/knowledge_base

# RAG
CHUNK_SIZE=800
CHUNK_OVERLAP=100
TOP_K=4
